
# My School Buddies Environment Configuration
# Copy this file to .env and update with your actual values

# Application
NODE_ENV=development
APP_NAME=My School Buddies
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Database Configuration (PostgreSQL)
DB_HOST=pg.hostingmanager.in
DB_PORT=5432
DB_NAME=myschoolbuddies_budibase_db
DB_USER=msbfinalroot
DB_PASSWORD=vA5ZXB2Nb6M3P22GWZRch999

# Keycloak Authentication
KEYCLOAK_URL=https://login.hostingmanager.in
KEYCLOAK_REALM=myschoolbuddies-realm
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=S@feAdminKeycloak!2025

# Keycloak Client Configuration
KEYCLOAK_FRONTEND_CLIENT_ID=frontend-client
KEYCLOAK_FRONTEND_CLIENT_SECRET=frontend-client-secret-2025
KEYCLOAK_BACKEND_CLIENT_ID=backend-client
KEYCLOAK_BACKEND_CLIENT_SECRET=backend-client-secret-2025

# SendGrid Email Configuration
SENDGRID_API_KEY=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
SENDGRID_FROM_EMAIL=noreply@myschoolbuddies.com
SENDGRID_FROM_NAME=My School Buddies

# Redis Configuration (for sessions and caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# File Upload Configuration
MAX_FILE_SIZE=10MB
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
BCRYPT_ROUNDS=12

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Production SSL (for deployment)
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/private.key

# Monitoring and Health Checks
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=true

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_FILE_UPLOADS=true
ENABLE_BULK_UPLOAD=true
ENABLE_CHAT_MODERATION=true

# External Services (Optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=
MIXPANEL_TOKEN=

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=./backups
