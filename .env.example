# =============================================
# Canonical Environment Variables (.env.example)
# All secrets here are placeholders. Copy to .env and set real values.
# =============================================

# Global
NODE_ENV=production
APP_NAME=My School Buddies
APP_VERSION=1.0.0

# ---------------------------------------------
# Backend
# ---------------------------------------------
PORT=3033
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# Keycloak
KEYCLOAK_URL=https://login.example.com
KEYCLOAK_REALM=myschoolbuddies-realm
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:8080

# Email (SendGrid or compatible SMTP provider)
SENDGRID_API_KEY=change-me
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME=My School Buddies

# Registration / Import config
REGISTRATION_MODE=invite # options: invite | self_moderated | self_email_verified
AUTO_APPROVE_PLATFORM_UPLOADS=false
IMPORT_STAGING_RETENTION_DAYS=30

# Security & Logging
SESSION_SECRET=change-me-session-secret
JWT_SECRET=change-me-jwt-secret
LOG_LEVEL=info

# ---------------------------------------------
# Frontend (Vite)
# ---------------------------------------------
VITE_API_URL=/api
VITE_KEYCLOAK_URL=https://login.example.com
VITE_KEYCLOAK_REALM=myschoolbuddies-realm
VITE_KEYCLOAK_CLIENT_ID=myschoolbuddies-frontend
VITE_OAUTH2_REDIRECT_URI=http://localhost:8080/oauth2/callback
