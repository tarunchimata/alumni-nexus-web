generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AlumniProfile {
  id              String  @id
  userId          String  @unique
  graduationYear  Int
  currentCompany  String?
  currentPosition String?
  linkedInUrl     String?
  User            User    @relation(fields: [userId], references: [id])
}

model LoginAudit {
  id        String   @id
  userId    String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model School {
  id                   String                @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                 String
  code                 String?               @unique
  establishmentYear    Int?                  @default(2000)
  email                String?
  phone                String?
  website              String?
  addressLine1         String?
  addressLine2         String?
  city                 String?
  state                String?
  country              String?
  postalCode           String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @default(now())
  affiliationHsec      String?
  affiliationSec       String?
  category             String?
  classFrom            Int?
  classTo              Int?
  district             String?
  management           String?
  subDistrict          String?
  type                 String?
  SchoolApprovalPolicy SchoolApprovalPolicy?
  User                 User[]

  @@index([name])
  @@index([category], map: "idx_school_category")
  @@index([district], map: "idx_school_district")
  @@index([name], map: "idx_school_name")
  @@index([name(ops: raw("gin_trgm_ops"))], map: "idx_school_name_trgm", type: Gin)
  @@index([state, district, name], map: "idx_school_search")
  @@index([state], map: "idx_school_state")
  @@index([state, district], map: "idx_school_state_district")
  @@index([type], map: "idx_school_type")
}

model SchoolApprovalPolicy {
  id                           String  @id
  schoolId                     String  @unique
  requireTeacherVerification   Boolean @default(false)
  requirePrincipalVerification Boolean @default(false)
  multiStepApprovalEnabled     Boolean @default(false)
  verificationTimeoutHours     Int     @default(48)
  School                       School  @relation(fields: [schoolId], references: [id])
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model SchoolSubmission {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  city              String?
  district          String?
  state             String?
  postalCode        String?
  type              String?
  management        String?
  code              String?
  status            String?   @default("PENDING")
  submittedBy       String?
  reviewedBy        String?
  reviewedAt        DateTime? @db.Timestamp(6)
  rejectionReason   String?
  createdAt         DateTime? @default(now()) @db.Timestamp(6)
  updatedAt         DateTime? @default(now()) @db.Timestamp(6)
  establishmentYear Int?

  @@index([createdAt], map: "idx_submission_created_at")
  @@index([status], map: "idx_submission_status")
}

model StudentProfile {
  id          String  @id
  userId      String  @unique
  admissionNo String?
  class       String
  section     String?
  rollNumber  String?
  User        User    @relation(fields: [userId], references: [id])
}

model TeacherProfile {
  id          String  @id
  userId      String  @unique
  employeeId  String?
  department  String?
  designation String?
  User        User    @relation(fields: [userId], references: [id])
}

model User {
  id             String          @id
  keycloakId     String          @unique
  email          String          @unique
  firstName      String
  middleName     String?
  lastName       String
  fullName       String
  phone          String?
  gender         Gender?
  dateOfBirth    DateTime?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  country        String?
  postalCode     String?
  role           UserRole
  joinYear       Int
  passOutYear    Int?
  isActive       Boolean         @default(false)
  isVerified     Boolean         @default(false)
  schoolId       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  approvalStatus ApprovalStatus  @default(PENDING)
  approvedAt     DateTime?
  approvedById   String?
  deletedAt      DateTime?
  AlumniProfile  AlumniProfile?
  LoginAudit     LoginAudit[]
  StudentProfile StudentProfile?
  TeacherProfile TeacherProfile?
  User           User?           @relation("UserToUser", fields: [approvedById], references: [id])
  other_User     User[]          @relation("UserToUser")
  School         School?         @relation(fields: [schoolId], references: [id])

  @@index([role])
  @@index([schoolId])
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model schools_api {
  id             Int       @id @default(autoincrement())
  institution_id String?   @unique @db.VarChar(50)
  school_name    String    @db.VarChar(255)
  village_name   String?   @db.VarChar(255)
  district_name  String?   @db.VarChar(255)
  state_name     String?   @db.VarChar(255)
  pincode        String?   @db.VarChar(10)
  school_type    String?   @db.VarChar(100)
  management     String?   @db.VarChar(100)
  status         String?   @db.VarChar(50)
  location_type  String?   @db.VarChar(50)
  is_active      Boolean?  @default(true)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)

  @@index([is_active], map: "idx_schools_api_active")
  @@index([institution_id], map: "idx_schools_api_institution_id")
  @@index([school_name], map: "idx_schools_api_name")
  @@index([state_name, district_name], map: "idx_schools_api_state_district")
  @@index([village_name], map: "idx_schools_api_village")
}

enum SchoolType {
  Primary          @map("Primary")
  Secondary        @map("Secondary")
  Higher_Secondary @map("Higher Secondary")
}

enum ManagementType {
  Government @map("Government")
  Private    @map("Private")
}

enum UserRole {
  super_admin
  school_admin
  teacher
  student
  alumni
  parent
}

enum ClassRole {
  teacher
  student
  alumni
  admin
}

enum MessageType {
  text
  image
  file
}

enum GroupType {
  class_alumni
  batch_alumni
  school_alumni
  interest_group
  study_group
  professional
}

enum GroupMemberRole {
  admin
  moderator
  member
}

enum NotificationType {
  message
  group_message
  connection_request
  connection_accepted
  post_reaction
  post_comment
  group_invitation
  mention
  system
}

enum PostType {
  text
  image
  video
  link
  event
}

enum PostVisibility {
  public
  school_only
  alumni_only
  connections_only
  private
}

enum ReactionType {
  like
  love
  celebrate
  support
  insightful
}

enum ConnectionStatus {
  pending
  accepted
  blocked
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}
