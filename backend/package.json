{
  "name": "myschoolbuddies-backend",
  "version": "1.0.0",
  "description": "My School Buddies Platform Backend API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && prisma generate",
    "start": "ts-node src/index.ts",
    "dev": "ts-node --project ./tsconfig.json --transpile-only src/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "import-schools": "ts-node src/scripts/importSchools.ts",
    "import-schools-bulk": "ts-node src/scripts/importSchoolsBulk.ts",
    "import-schools-optimized": "ts-node src/scripts/importSchoolsOptimized.ts",
    "import-users": "ts-node src/scripts/importUsers.ts",
    "import-users-bulk": "ts-node src/scripts/importUsersBulk.ts",
    "import-users-optimized": "ts-node src/scripts/importUsersOptimized.ts",
    "generate-users": "ts-node src/scripts/generateUsers.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "@keycloak/keycloak-admin-client": "^26.3.1",
    "@prisma/client": "^5.7.1",
    "@sendgrid/mail": "^8.1.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/csurf": "^1.11.5",
    "@types/jsonwebtoken": "^9.0.5",
    "axios": "^1.6.2",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "inquirer": "^12.9.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.2",
    "keycloak-connect": "^23.0.3",
    "multer": "1.4.4-lts.1",
    "pg": "^8.11.3",
    "prisma": "^5.7.1",
    "socket.io": "^4.8.1",
    "typescript": "^5.3.3",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/inquirer": "^9.0.8",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
