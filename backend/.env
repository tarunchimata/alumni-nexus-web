
# My School Buddies Backend Environment Configuration

# Application
NODE_ENV=development
PORT=3001
APP_NAME=My School Buddies Backend
APP_URL=http://localhost:3001

# Database Configuration (Hosted PostgreSQL)
DATABASE_URL="postgresql://msbfinalroot:vA5ZXB2Nb6M3P22GWZRch999@pg.hostingmanager.in:5432/myschoolbuddies_budibase_db"

# OAuth2 Configuration
USE_OAUTH2=true
KEYCLOAK_FRONTEND_CLIENT_ID=myschoolbuddies-client
KEYCLOAK_FRONTEND_CLIENT_SECRET=
# OAUTH2_REDIRECT_URI will be determined dynamically by frontend

# Keycloak Configuration (Hosted)
KEYCLOAK_URL=https://login.hostingmanager.in
KEYCLOAK_REALM=myschoolbuddies-realm
KEYCLOAK_CLIENT_ID=myschoolbuddies-backend-client
KEYCLOAK_CLIENT_SECRET=backend-client-secret-2025
KEYCLOAK_BACKEND_CLIENT_ID=myschoolbuddies-backend-client
KEYCLOAK_BACKEND_CLIENT_SECRET=backend-client-secret-2025

# Keycloak Admin API
KEYCLOAK_ADMIN_USERNAME=admin@myschoolbuddies.com
KEYCLOAK_ADMIN_PASSWORD=S@feAdminKeycloak!2025

# Cookie Configuration
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# SendGrid Email Configuration
SENDGRID_API_KEY=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
SENDGRID_FROM_EMAIL=noreply@myschoolbuddies.com
SENDGRID_FROM_NAME=My School Buddies

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
BCRYPT_ROUNDS=12

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# File Upload Configuration
MAX_FILE_SIZE=10MB
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,csv

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_FILE_UPLOADS=true
ENABLE_BULK_UPLOAD=true
