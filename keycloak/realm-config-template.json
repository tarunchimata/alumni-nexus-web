
{
  "realm": "${KEYCLOAK_REALM_NAME}",
  "enabled": true,
  "displayName": "${KEYCLOAK_REALM_DISPLAY_NAME}",
  "displayNameHtml": "<div class=\"kc-logo-text\"><span>${KEYCLOAK_REALM_DISPLAY_NAME}</span></div>",
  "loginTheme": "keycloak",
  "accountTheme": "keycloak",
  "adminTheme": "keycloak",
  "emailTheme": "keycloak",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 30,
  "smtpServer": {
    "host": "${KEYCLOAK_SMTP_HOST}",
    "port": ${KEYCLOAK_SMTP_PORT},
    "from": "${KEYCLOAK_SMTP_FROM}",
    "fromDisplayName": "${KEYCLOAK_SMTP_FROM_DISPLAY_NAME}",
    "ssl": "${KEYCLOAK_SMTP_SSL}",
    "starttls": "${KEYCLOAK_SMTP_STARTTLS}",
    "auth": "${KEYCLOAK_SMTP_AUTH}",
    "user": "${KEYCLOAK_SMTP_USER}",
    "password": "${KEYCLOAK_SMTP_PASSWORD}"
  },
  "roles": {
    "realm": [
      { "name": "platform_admin", "description": "Platform Administrator with full system access" },
      { "name": "school_admin", "description": "School Administrator managing school-specific resources" },
      { "name": "teacher", "description": "Teacher with access to assigned classes" },
      { "name": "student", "description": "Student with access to enrolled classes" },
      { "name": "alumni", "description": "Alumni with access to school community" }
    ]
  },
  "clients": [
    {
      "clientId": "myschoolbuddies-client",
      "name": "My School Buddies Frontend",
      "description": "React frontend public client - PKCE enabled",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "fullScopeAllowed": false,
      "redirectUris": ${KEYCLOAK_FRONTEND_REDIRECT_URIS},
      "webOrigins": ${KEYCLOAK_FRONTEND_WEB_ORIGINS},
      "attributes": {
        "post.logout.redirect.uris": "${KEYCLOAK_FRONTEND_POST_LOGOUT_URIS}",
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["web-origins", "profile", "roles", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access", "school-access", "class-access"]
    },
    {
      "clientId": "myschoolbuddies-backend-client",
      "name": "My School Buddies Backend API",
      "description": "Backend confidential client for server-to-server communication",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "${KEYCLOAK_BACKEND_CLIENT_SECRET}",
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false
    }
  ],
  "clientScopes": [
    {
      "name": "school-access",
      "description": "Access to school-specific resources",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "class-access",
      "description": "Access to class-specific resources",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    }
  ],
  "users": [
    {
      "username": "${KEYCLOAK_ADMIN_USERNAME}",
      "email": "${KEYCLOAK_ADMIN_EMAIL}",
      "firstName": "${KEYCLOAK_ADMIN_FIRST_NAME}",
      "lastName": "${KEYCLOAK_ADMIN_LAST_NAME}",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "${KEYCLOAK_ADMIN_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": ["platform_admin"],
      "attributes": {
        "school_id": [""],
        "user_type": ["platform_admin"]
      }
    }
  ],
  "requiredActions": [
    {
      "alias": "VERIFY_EMAIL",
      "name": "Verify Email",
      "providerId": "VERIFY_EMAIL",
      "enabled": true,
      "defaultAction": true
    },
    {
      "alias": "UPDATE_PASSWORD",
      "name": "Update Password",
      "providerId": "UPDATE_PASSWORD",
      "enabled": true,
      "defaultAction": false
    }
  ],
  "attributes": {
    "frontendUrl": "${KEYCLOAK_FRONTEND_URL}",
    "adminUrl": "${KEYCLOAK_ADMIN_URL}"
  }
}
