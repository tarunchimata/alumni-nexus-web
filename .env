
# =============================================
# My School Buddies Environment Configuration
# =============================================

# Application
NODE_ENV=development
APP_NAME=My School Buddies
APP_URL=http://localhost:3000

# =============================================
# OAuth2 Configuration (Frontend)
# =============================================
VITE_USE_OAUTH2=true
VITE_KEYCLOAK_URL=https://login.hostingmanager.in
VITE_KEYCLOAK_REALM=myschoolbuddies-realm
VITE_KEYCLOAK_CLIENT_ID=myschoolbuddies-client

# Development configuration (HTTP to avoid mixed content issues)
VITE_PUBLIC_URL=http://localhost:8080
VITE_OAUTH2_REDIRECT_URI=http://localhost:8080/auth/callback
VITE_API_BASE_URL=https://api.hostingmanager.in/api
VITE_BACKEND_API_URL=https://api.hostingmanager.in
VITE_API_URL=https://api.hostingmanager.in/api
VITE_SOCKET_URL=https://api.hostingmanager.in

# =============================================
# Database Configuration (PostgreSQL)
# =============================================
DB_HOST=pg.hostingmanager.in
DB_PORT=5432
DB_NAME=myschoolbuddies_budibase_db
